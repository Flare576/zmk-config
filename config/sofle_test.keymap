/*
 * Sofle v2.0w - Hardware verification keymap
 *
 * Each key outputs a unique, position-identifiable character.
 * Rows are labeled by a leading character so a bad joint is immediately obvious:
 *
 * LEFT HALF                                RIGHT HALF
 * ╭─────────────────────────────────╮      ╭─────────────────────────────────╮
 * │ `  1  2  3  4  5                │      │           6  7  8  9  0  -      │
 * │ !  q  w  e  r  t                │      │           y  u  i  o  p  =      │
 * │ @  a  s  d  f  g                │      │           h  j  k  l  ;  '      │
 * │ #  z  x  c  v  b  [ENC]        │      │     [ENC] n  m  ,  .  /  \      │
 * │       $  %  ^  &  (             │      │           )  *  _  +  |  ~      │
 * ╰─────────────────────────────────╯      ╰─────────────────────────────────╯
 *
 * Encoders: Left = A/B, Right = C/D
 *
 * When a key doesn't fire, you know exactly which socket to reflow.
 */

#include <behaviors.dtsi>
#include <dt-bindings/zmk/keys.h>

&nice_view_spi {
    cs-gpios = <&pro_micro 0 GPIO_ACTIVE_HIGH>;
};

/ {
    keymap {
        compatible = "zmk,keymap";

        test_layer {
            label = "Test";
            bindings = <
// ╭──────┬──────┬──────┬──────┬──────┬──────╮                    ╭──────┬──────┬──────┬──────┬──────┬──────╮
   &kp GRAVE &kp N1 &kp N2 &kp N3 &kp N4 &kp N5                   &kp N6 &kp N7 &kp N8 &kp N9 &kp N0 &kp MINUS
// ├──────┼──────┼──────┼──────┼──────┼──────┤                    ├──────┼──────┼──────┼──────┼──────┼──────┤
   &kp EXCL &kp Q &kp W  &kp E  &kp R  &kp T                      &kp Y  &kp U  &kp I  &kp O  &kp P  &kp EQUAL
// ├──────┼──────┼──────┼──────┼──────┼──────┤                    ├──────┼──────┼──────┼──────┼──────┼──────┤
   &kp AT  &kp A  &kp S  &kp D  &kp F  &kp G                      &kp H  &kp J  &kp K  &kp L  &kp SEMI &kp SQT
// ├──────┼──────┼──────┼──────┼──────┼──────┼──────╮╭──────┬─────┼──────┼──────┼──────┼──────┼──────┼──────┤
   &kp HASH &kp Z &kp X  &kp C  &kp V  &kp B  &kp LBKT  &kp RBKT  &kp N  &kp M  &kp COMMA &kp DOT &kp FSLH &kp BSLH
// ╰──────┴──────┴──────┼──────┼──────┼──────┼──────╯╰──────┴─────┼──────┼──────┼──────┼──────┴──────┴──────╯
                        &kp DLLR &kp PRCNT &kp CARET &kp AMPS &kp LPAR  &kp RPAR &kp STAR &kp UNDER &kp PLUS &kp TILDE
//                      ╰──────┴──────┴──────┴──────╯╰──────┴─────┴──────┴──────┴──────╯
            >;
            // Left encoder: A (ccw) / B (cw)   Right encoder: C (ccw) / D (cw)
            sensor-bindings = <&inc_dec_kp A B &inc_dec_kp C D>;
        };
    };
};
